<script>
    const sb = supabase.createClient('URL', 'KEY'); // Hier deine Daten lassen

    const html5QrCode = new Html5Qrcode("reader");
    const userEmail = localStorage.getItem('midus_user'); // Wer scannt gerade?

    html5QrCode.start(
        { facingMode: "environment" }, 
        { fps: 10, qrbox: 250 },
        async (billCode) => {
            html5QrCode.stop();
            document.getElementById('status').innerText = "Prüfe Rechnung...";

            // 1. Prüfen, ob der Code schon benutzt wurde
            const { data: existing } = await sb.from('transactions').select('*').eq('bill_code', billCode).single();
            
            if (existing) {
                alert("Dieser QR-Code wurde bereits eingelöst!");
            } else {
                // 2. Transaktion speichern (verriegeln)
                await sb.from('transactions').insert([{ bill_code: billCode, user_email: userEmail }]);
                
                // 3. Punkte beim User erhöhen
                const { data: user } = await sb.from('vip_guests').select('points').eq('email', userEmail).single();
                const newPoints = (user.points || 0) + 10;
                await sb.from('vip_guests').update({ points: newPoints }).eq('email', userEmail);
                
                alert("Erfolg! 10 Punkte gutgeschrieben.");
            }
            window.location.href = "index.html";
        },
        (err) => {}
    );
</script>
